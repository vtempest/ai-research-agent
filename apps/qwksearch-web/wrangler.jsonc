{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "qwksearch",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "qwksearch",
      "database_id": "9f45c816-5b19-43e0-8e4e-9edbd6c115b0",
    },
  ],
  "env": {
    "production": {
      "keep_vars": true,
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "qwksearch",
          "database_id": "9f45c816-5b19-43e0-8e4e-9edbd6c115b0",
        },
      ],
    },
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
}
