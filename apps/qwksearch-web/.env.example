
# -------------------- Database --------------------
# Local SQLite file for dev (D1 binding is used in production via wrangler.jsonc)
DATABASE_URL=file:./data/qwksearch.db

# -------------------- Authentication --------------------
# Better-Auth secret key (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-here

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Required for Google Sign-In and Google One Tap
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Application Base URL (required for OAuth callbacks)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Better Auth base URL (must match NEXT_PUBLIC_BASE_URL; required for OAuth redirect URIs)
BETTER_AUTH_URL=http://localhost:3000

# Optional OAuth Providers
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Email Authentication (Resend for magic links)
AUTH_RESEND_KEY=

# -------------------- AI Provider APIs --------------------
# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Google AI (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# -------------------- Search & Data APIs --------------------
# Tavily Search API (https://tavily.com)
TAVILY_API_KEY=


# -------------------- Search Engine --------------------
# SearxNG instance URL (optional - uses public instance if not set)
SEARXNG_API_URL=http://localhost:4000

# -------------------- Cloudflare R2 Storage --------------------
# Get credentials from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOADS_BUCKET=qwksearch-uploads
