    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "terser": "^5.46.0",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
