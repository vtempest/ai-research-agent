{
  "name": "ai-research-agent",
  "version": "1.2.1",
  "module": "index.ts",
  "description": "Separch, extract, vectorize, outline graph, and monitor the web for a topic with AI Research Agent.",
  "author": "vtempest <grokthiscontact@gmail.com>",
  "license": "rights.institute/PROSPER",
  "main": "./src/index.ts",
  "types": "./src/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/research-agent.es.js",
      "require": "./dist/research-agent.cjs.js"
    },
    "./*": "./src/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "ship": "npx standard-version --release-as patch; npm publish",
    "test-ui": "vitest --ui --watch",
    "make": "rm -rf dist/*; NODE_OPTIONS=--max-old-space-size=15192 BUN_JSC_forceRAMSize=15192  vite build "
  },
  "peerDependencies": {
    "next": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
