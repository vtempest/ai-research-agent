    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.13",
    "@langchain/xai": "^1.3.9",
    "chrono-node": "^2.9.0",
    "drizzle-orm": "^0.45.1",
    "grab-url": "^1.6.7",
