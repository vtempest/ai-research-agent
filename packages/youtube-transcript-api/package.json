{
  "name": "extract-youtube",
  "version": "1.0.2",
  "description": "Fast, no-browser serverless-optimized YouTube transcript extractor",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": "dist/cli.js",
  "scripts": {
    "build": "npm run build:types && npm run build:lib && npm run build:cli",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationMap",
    "build:lib": "vite build",
    "build:cli": "BUILD_CLI=true vite build",
    "build:bundle": "npm run build:lib && npm run build:cli",
    "build:legacy": "tsc",
    "prepare": "npm run build",
    "ship": "npx standard-version --release-as patch; npm publish",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "youtube",
    "transcript",
    "subtitles",
    "captions",
    "api",
    "serverless",
    "lambda",
    "vercel",
    "cloudflare",
    "edge",
    "typescript",
    "youtube-transcript",
    "youtube-transcript-api",
    "srt",
    "webvtt",
    "video",
    "parsing",
    "extraction",
    "optimized"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^4.2.5",
    "html-entities": "^2.3.3",
    "https-proxy-agent": "^5.0.1",
    "node-fetch": "^2.6.7",
    "youtube-transcript-api": "^3.0.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": ">=22.12.0",
    "@types/node-fetch": "^2.6.2",
    "jest": "^29.5.0",
    "terser": "^5.46.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
