{
  "name": "qwksearch",
  "private": true,
  "version": "2.2.0",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo dev --filter=qwksearch-web",
    "build:web": "turbo build --filter=qwksearch-web",
    "dev:editor": "turbo dev --filter=reason-editor",
    "build:editor": "turbo build --filter=reason-editor"
  },
  "devDependencies": {
    "turbo": "^2.8.14"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@opennextjs/cloudflare"
  ],
  "resolutions": {
    "@vitejs/plugin-react": "5.2.0",
    "@opennextjs/aws": "3.9.16"
  }
}
